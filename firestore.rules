rules_version = '2';

service cloud.firestore {
  match /databases/{database}/documents {

    // Portfolio content — admin-managed
    match /site/{document=**} {
      allow read: if true;
      allow write: if request.time < timestamp.date(2027, 1, 1);
    }

    // Chain Reaction multiplayer games
    match /games/{gameId} {
      allow read: if true;
      allow create: if request.resource.data.keys().hasAll([
        'grid', 'currentPlayer', 'activePlayers', 'hasPlayed',
        'gameOver', 'winner', 'playerCount', 'status', 'slots'
      ]);
      allow update: if resource.data.status != 'finished'
                    || request.resource.data.status == 'finished';
    }
  }
}
